5. Chat Window Component
chat-window.component.ts
import { Component, OnInit } from '@angular/core';
import { ChatService } from '../../services/chat.service';
import { ChatMessage } from '../../models/chat-message.model';
import { ChatSession } from '../../models/chat-session.model';

@Component({
  selector: 'app-chat-window',
  templateUrl: './chat-window.component.html',
  styleUrls: ['./chat-window.component.scss']
})
export class ChatWindowComponent implements OnInit {

  messages: ChatMessage[] = [];
  sessions: ChatSession[] = [];
  selectedSession?: ChatSession;

  inputText = '';
  selectedModel = 'gpt-4';

  minimized = false;

  models = ['gpt-4','gpt-4o','gpt-3.5'];

  constructor(private chatService: ChatService) {}

  ngOnInit() {
    this.loadSessions();
  }

  loadSessions() {
    this.chatService.getSessions().subscribe(res => {
      this.sessions = res;
    });
  }

  newSession() {
    this.chatService.createSession().subscribe(session => {
      this.selectedSession = session;
      this.messages = [];
      this.sessions.unshift(session);
    });
  }

  selectSession(session: ChatSession) {
    this.selectedSession = session;
    this.chatService.getSessionMessages(session.id)
      .subscribe(msgs => this.messages = msgs);
  }

  sendMessage() {

    if(!this.inputText.trim()) return;

    const userMessage: ChatMessage = {
      role: 'user',
      content: this.inputText,
      timestamp: new Date()
    };

    this.messages.push(userMessage);

    this.chatService
      .sendMessage(this.selectedSession!.id, this.inputText, this.selectedModel)
      .subscribe(res => {
        this.messages.push(res);
      });

    this.inputText = '';
  }

  upload(event:any){
    const file = event.target.files[0];
    this.chatService.uploadFile(file).subscribe();
  }

}
