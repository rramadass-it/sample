@RestController
@RequestMapping("/api/chat")
public class ChatController {

@PostMapping("/send")
public ChatMessage send(@RequestBody ChatRequest req){

   ChatMessage msg = new ChatMessage();
   msg.setRole("assistant");
   msg.setContent("Dummy response for: " + req.getMessage());

   return msg;
}

@PostMapping("/session")
public ChatSession newSession(){
   return new ChatSession(UUID.randomUUID().toString(),"New Chat");
}

@GetMapping("/sessions")
