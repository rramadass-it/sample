2. Chat Service (REST Calls)
chat.service.ts
import { Injectable } from '@angular/core';
import { HttpClient } from '@angular/common/http';
import { Observable } from 'rxjs';

@Injectable({
  providedIn: 'root'
})
export class ChatService {

  private API = "/api/chat";

  constructor(private http: HttpClient) {}

  sendMessage(sessionId: string, message: string, model: string): Observable<any> {
    return this.http.post(`${this.API}/send`, {
      sessionId,
      message,
      model
    });
  }

  getSessions(): Observable<any> {
    return this.http.get(`${this.API}/sessions`);
  }

  createSession(): Observable<any> {
    return this.http.post(`${this.API}/session`, {});
  }

  uploadFile(file: File): Observable<any> {
    const form = new FormData();
    form.append("file", file);
    return this.http.post(`${this.API}/upload`, form);
  }

}
3. Chat Component Logic
chat.component.ts
import { Component, OnInit } from '@angular/core';
import { ChatService } from './chat.service';

@Component({
  selector: 'app-chat',
  templateUrl: './chat.component.html',
  styleUrls: ['./chat.component.scss']
})
export class ChatComponent implements OnInit {

  isOpen = false;
  minimized = false;
  showSettings = false;

  messageText = "";
  selectedModel = "gpt-4";

  messages:any[] = [];
  sessions:any[] = [];
  currentSession:any;

  models = ["gpt-4","gpt-4o","gpt-3.5"];

  constructor(private chatService:ChatService){}

  ngOnInit(){
    this.loadSessions();
  }

  openChat(){
    this.isOpen = true;
  }

  closeChat(){
    this.isOpen = false;
  }

  minimize(){
    this.minimized = !this.minimized;
  }

  loadSessions(){
    this.chatService.getSessions().subscribe(res=>{
      this.sessions = res || [];
    });
  }

  newSession(){
    this.chatService.createSession().subscribe(res=>{
      this.currentSession = res;
      this.messages = [];
      this.sessions.unshift(res);
    });
  }

  selectSession(session:any){
    this.currentSession = session;
    this.messages = session.messages || [];
  }

  send(){

    if(!this.messageText.trim()) return;

    const userMsg = {
      role:'user',
      content:this.messageText
    };

    this.messages.push(userMsg);

    this.chatService
      .sendMessage(this.currentSession?.id,this.messageText,this.selectedModel)
      .subscribe(res=>{
        this.messages.push(res);
      });

    this.messageText="";
  }

  upload(event:any){
    const file = event.target.files[0];
    this.chatService.uploadFile(file).subscribe();
  }

}
4. Chat Interface
chat.component.html
<!-- Chat Open Button -->
<button class="chat-open-btn" (click)="openChat()">💬 Chat</button>


<!-- Chat Window -->
<div class="chat-window" *ngIf="isOpen">

  <!-- HEADER -->
  <div class="chat-header">

    <span>AI Assistant</span>

    <select [(ngModel)]="selectedModel">
      <option *ngFor="let m of models">{{m}}</option>
    </select>

    <div>

      <button (click)="showSettings=!showSettings">⚙</button>
      <button (click)="minimize()">—</button>
      <button (click)="closeChat()">✕</button>

    </div>

  </div>


  <!-- SETTINGS -->
  <div class="settings" *ngIf="showSettings">

    <h4>Settings</h4>

    <label>
      Default Model
      <select [(ngModel)]="selectedModel">
        <option *ngFor="let m of models">{{m}}</option>
      </select>
    </label>

  </div>


  <div class="chat-body" *ngIf="!minimized">

    <!-- HISTORY -->
    <div class="history">

      <button (click)="newSession()">+ New Chat</button>

      <div
        class="session"
        *ngFor="let s of sessions"
        (click)="selectSession(s)"
      >
        {{s.title || 'Chat'}}
      </div>

    </div>


    <!-- MESSAGES -->
    <div class="messages">

      <div
        *ngFor="let msg of messages"
        class="message"
        [ngClass]="msg.role"
      >

        {{msg.content}}

      </div>

    </div>

  </div>


  <!-- FOOTER -->
  <div class="chat-footer" *ngIf="!minimized">

    <input
      type="text"
      placeholder="Type message..."
      [(ngModel)]="messageText"
      (keydown.enter)="send()"
    />

    <input type="file" (change)="upload($event)"/>

    <button (click)="send()">Send</button>

  </div>

</div>
