7. Chat Window Component
components/chat-window.component.ts
import { Component } from '@angular/core';
import { ChatService } from '../../services/chat.service';
import { ChatApiService } from '../../services/chat-api.service';
import { v4 as uuid } from 'uuid';

@Component({
  selector: 'app-chat-window',
  standalone: true,
  templateUrl: './chat-window.component.html',
  styleUrls: ['./chat-window.component.scss']
})
export class ChatWindowComponent {

  message = '';
  selectedModel = 'gpt-4';
  file: File | null = null;

  constructor(
    public chatService: ChatService,
    private api: ChatApiService
  ) {}

  send() {

    const session = this.chatService.activeSession$.value;
    if (!session) return;

    const userMessage = {
      id: uuid(),
      sessionId: session.id,
      sender: 'user',
      message: this.message,
      timestamp: new Date()
    };

    this.chatService.addMessage(userMessage);

    this.api.sendMessage({
      sessionId: session.id,
      message: this.message,
      model: this.selectedModel
    }).subscribe((res: any) => {

      const botMsg = {
        id: uuid(),
        sessionId: session.id,
        sender: 'assistant',
        message: res.reply || "Dummy response from backend",
        timestamp: new Date()
      };

      this.chatService.addMessage(botMsg);

    });

    this.message = '';
  }

  uploadFile(event: any) {
    this.file = event.target.files[0];
  }

}
8. Chat Window HTML
chat-window.component.html
<div class="chat-window" *ngIf="chatService.chatOpen$ | async">

  <div class="chat-header">

    <span>AI Chat</span>

    <div class="actions">
      <button mat-icon-button (click)="chatService.minimized$.next(true)">
        <mat-icon>remove</mat-icon>
      </button>

      <button mat-icon-button (click)="chatService.chatOpen$.next(false)">
        <mat-icon>close</mat-icon>
      </button>
    </div>

  </div>

  <div class="chat-body">

    <div *ngFor="let msg of chatService.messages$ | async">

      <div class="msg user" *ngIf="msg.sender === 'user'">
        {{msg.message}}
      </div>

      <div class="msg assistant" *ngIf="msg.sender === 'assistant'">
        {{msg.message}}
      </div>

    </div>

  </div>

  <div class="chat-controls">

    <select [(ngModel)]="selectedModel">
      <option value="gpt4">GPT-4</option>
      <option value="gpt35">GPT-3.5</option>
      <option value="custom">Custom Model</option>
    </select>

    <input type="file" (change)="uploadFile($event)">

  </div>

  <div class="chat-input">

    <input
      [(ngModel)]="message"
      placeholder="Type message..."
      (keydown.enter)="send()"
    >

    <button mat-raised-button color="primary" (click)="send()">
      Send
    </button>

  </div>

</div>
