4. Chat API Service (REST integration)
services/chat-api.service.ts

Replace endpoints later with Spring API.

import { Injectable } from '@angular/core';
import { HttpClient } from '@angular/common/http';
import { Observable } from 'rxjs';

@Injectable({ providedIn: 'root' })
export class ChatApiService {

  private BASE_URL = '/api/chat';

  constructor(private http: HttpClient) {}

  sendMessage(payload: any): Observable<any> {
    return this.http.post(`${this.BASE_URL}/send`, payload);
  }

  getSessions(): Observable<any> {
    return this.http.get(`${this.BASE_URL}/sessions`);
  }

  getSessionMessages(sessionId: string): Observable<any> {
    return this.http.get(`${this.BASE_URL}/messages/${sessionId}`);
  }

  createSession(model: string): Observable<any> {
    return this.http.post(`${this.BASE_URL}/session`, { model });
  }

}
5. Chat State Service
services/chat.service.ts
import { Injectable } from '@angular/core';
import { BehaviorSubject } from 'rxjs';
import { ChatSession } from '../models/chat-session.model';
import { ChatMessage } from '../models/chat-message.model';
import { v4 as uuid } from 'uuid';

@Injectable({ providedIn: 'root' })
export class ChatService {

  sessions$ = new BehaviorSubject<ChatSession[]>([]);
  activeSession$ = new BehaviorSubject<ChatSession | null>(null);
  messages$ = new BehaviorSubject<ChatMessage[]>([]);

  chatOpen$ = new BehaviorSubject<boolean>(false);
  minimized$ = new BehaviorSubject<boolean>(false);

  createSession(model: string) {

    const session: ChatSession = {
      id: uuid(),
      title: "New Chat",
      createdAt: new Date(),
      model
    };

    const sessions = this.sessions$.value;

    this.sessions$.next([session, ...sessions]);
    this.activeSession$.next(session);
    this.messages$.next([]);
  }

  addMessage(msg: ChatMessage) {

    const msgs = this.messages$.value;
    this.messages$.next([...msgs, msg]);

  }

}
