🔥 DynamicToolRegistry.java
@Component
public class DynamicToolRegistry {

    private final RestTemplate restTemplate;

    @Value("${mcp.base-url}")
    private String baseUrl;

    private Map<String, ToolDefinition> tools = new ConcurrentHashMap<>();

    public DynamicToolRegistry(RestTemplate restTemplate) {
        this.restTemplate = restTemplate;
    }

    @PostConstruct
    public void loadTools() {

        ResponseEntity<ToolDefinition[]> response =
                restTemplate.getForEntity(
                        baseUrl + "/tools",
                        ToolDefinition[].class
                );

        if (response.getBody() != null) {
            for (ToolDefinition tool : response.getBody()) {
                tools.put(tool.name(), tool);
            }
        }
    }

    public ToolDefinition get(String name) {
        return tools.get(name);
    }

    public Collection<ToolDefinition> getAll() {
        return tools.values();
    }
}
🧠 2. TOOL RANKING (Smart Selection)

👉 Instead of blindly letting LLM pick, we guide it.

Strategy

Embed tool descriptions

Compare with user query

Send top tools to LLM

Simple Ranking (Production-friendly)
public List<ToolDefinition> rankTools(String query) {

    return tools.values().stream()
            .sorted((t1, t2) ->
                    score(query, t2.description()) -
                    score(query, t1.description())
            )
            .limit(5)
            .toList();
}

private int score(String query, String desc) {
    return Arrays.stream(query.split(" "))
            .mapToInt(word -> desc.toLowerCase().contains(word.toLowerCase()) ? 1 : 0)
            .sum();
}
