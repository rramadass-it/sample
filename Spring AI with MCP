🧠 4. AGENT LOOP (MULTI-STEP REASONING 🔥)

👉 This is the MOST IMPORTANT PART

AgentService.java
@Service
public class AgentService {

    private final ChatClient chatClient;
    private final DynamicToolRegistry registry;
    private final ToolExecutor executor;

    public AgentService(ChatClient.Builder builder,
                        CustomMcpChatModel model,
                        DynamicToolRegistry registry,
                        ToolExecutor executor) {

        this.chatClient = builder.chatModel(model).build();
        this.registry = registry;
        this.executor = executor;
    }

    public String runAgent(String sessionId, String userInput) {

        String context = userInput;

        for (int step = 0; step < 5; step++) {

            // 🔥 Get top tools
            List<ToolDefinition> topTools = rankTools(context);

            // Ask LLM what to do next
            String decision = chatClient.prompt()
                    .system(buildSystemPrompt(topTools))
                    .user(context)
                    .call()
                    .content();

            if (decision.contains("FINAL_ANSWER")) {
                return decision;
            }

            // Parse tool call (simple format)
            String toolName = extractToolName(decision);
            String query = extractQuery(decision);

            ToolDefinition tool = registry.get(toolName);

            String result = executor.execute(tool, Map.of("query", query));

            logToolUsage(toolName, query);

            // Feed result back
            context = "Tool result: " + result;
        }

        return "Unable to complete request";
    }
}
🧠 5. SYSTEM PROMPT (CRITICAL)
private String buildSystemPrompt(List<ToolDefinition> tools) {

    String toolList = tools.stream()
            .map(t -> t.name() + ": " + t.description())
            .collect(Collectors.joining("\n"));

    return """
You are an AI agent.

You can use tools:

%s

Rules:
- If tool needed → respond:
  TOOL: tool-name | INPUT: query
- If final answer → respond:
  FINAL_ANSWER: your answer
""".formatted(toolList);
}
